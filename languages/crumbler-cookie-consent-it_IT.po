msgid "Crumbler – Cookie Consent"
msgstr ""

#. Plugin URI of the plugin
#: crumbler-cookie-consent.php
msgid "https://crumbler.ch"
msgstr ""

#. Description of the plugin
#: crumbler-cookie-consent.php
msgid "Connects your website to the Crumbler cookie consent service: consent banner, automatic script & iframe blocking, cookie declaration and Google Consent Mode v2."
msgstr "Collega il tuo sito web al servizio di consenso ai cookie Crumbler: banner di consenso, blocco automatico di script e iframe, dichiarazione sui cookie e Google Consent Mode v2."

