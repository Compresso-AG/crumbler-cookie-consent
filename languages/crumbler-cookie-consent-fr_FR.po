#. Plugin Name of the plugin
#: crumbler-cookie-consent.php
msgid "Crumbler – Cookie Consent"
msgstr ""

#. Plugin URI of the plugin
#: crumbler-cookie-consent.php
msgid "https://crumbler.ch"
msgstr ""

#. Description of the plugin
#: crumbler-cookie-consent.php
msgid "Connects your website to the Crumbler cookie consent service: consent banner, automatic script & iframe blocking, cookie declaration and Google Consent Mode v2."
msgstr "Connecte votre site web au service de consentement aux cookies Crumbler : bannière de consentement, blocage automatique des scripts et iframes, déclaration de cookies et Google Consent Mode v2."

#. Author of the plugin
#: crumbler-cookie-consent.php
msgid "Compresso AG"
msgstr ""

#. Author URI of the plugin
#: crumbler-cookie-consent.php
msgid "https://compresso.ch"
msgstr ""

#: crumbler-cookie-consent.php:76
#: blocks/cookie-declaration/editor.js:33
msgid "Settings"
msgstr "Réglages"

#: crumbler-cookie-consent.php:88
msgid "General Settings"
msgstr "Réglages généraux"

#: crumbler-cookie-consent.php:101
msgid "Enable Widget"
msgstr "Activer le widget"

#: crumbler-cookie-consent.php:115
msgid "Site Key"
msgstr ""

#: crumbler-cookie-consent.php:129
#: blocks/cookie-declaration/editor.js:35
msgid "Language"
msgstr "Langue"

#: crumbler-cookie-consent.php:138
msgid "Advanced Settings"
msgstr "Réglages avancés"

#: crumbler-cookie-consent.php:151
msgid "Widget URL"
msgstr "URL du widget"

#: crumbler-cookie-consent.php:165
msgid "Hide for Admins"
msgstr "Masquer pour les administrateurs"

#: crumbler-cookie-consent.php:181
msgid "The Site Key must be in UUID format (e.g. af232e06-59c2-4810-b09d-7a2b25632d1b)."
msgstr "Le Site Key doit être au format UUID (par ex. af232e06-59c2-4810-b09d-7a2b25632d1b)."

#: crumbler-cookie-consent.php:201
msgid "Connect your website to the Crumbler cookie consent service."
msgstr "Connectez votre site web au service de consentement aux cookies Crumbler."

#: crumbler-cookie-consent.php:205
msgid "Optional settings for special requirements."
msgstr "Réglages facultatifs pour des besoins particuliers."

#: crumbler-cookie-consent.php:216
msgid "Show Cookie Consent Widget on the website"
msgstr "Afficher le widget de consentement aux cookies sur le site web"

#. translators: %s: link to Crumbler Dashboard
#: crumbler-cookie-consent.php:225
#, php-format
msgid "You can find the Site Key in the %s under the respective site."
msgstr "Vous trouverez le Site Key dans le %s, sous le site correspondant."

#: crumbler-cookie-consent.php:233
msgid "Automatic (browser language)"
msgstr "Automatique (langue du navigateur)"

#: crumbler-cookie-consent.php:244
msgid "When set to \"Automatic\", the widget detects the visitor's browser language."
msgstr "En mode « Automatique », le widget détecte la langue du navigateur du visiteur."

#: crumbler-cookie-consent.php:250
msgid "Only change if you run your own widget instance. Leave empty for default."
msgstr "À modifier uniquement si vous exploitez votre propre instance du widget. Laisser vide pour la valeur par défaut."

#: crumbler-cookie-consent.php:257
msgid "Hide widget for logged-in administrators"
msgstr "Masquer le widget pour les administrateurs connectés"

#: crumbler-cookie-consent.php:357
msgid "Cookie Consent"
msgstr ""

#: crumbler-cookie-consent.php:365
msgid "Warning:"
msgstr "Avertissement :"

#: crumbler-cookie-consent.php:365
msgid "The widget is enabled but no Site Key has been entered. The widget will not work without a Site Key."
msgstr "Le widget est activé mais aucun Site Key n'a été saisi. Le widget ne fonctionne pas sans Site Key."

#. translators: 1: site name, 2: domain
#: crumbler-cookie-consent.php:380
#, php-format
msgid "Connected to Crumbler: %1$s is set up and active for %2$s. The widget is being served."
msgstr "Connecté à Crumbler : %1$s est configuré et actif pour %2$s. Le widget est diffusé."

#. translators: %s: domain
#: crumbler-cookie-consent.php:387
#, php-format
msgid "Connected to Crumbler: this domain (%s) is set up and active. The widget is being served."
msgstr "Connecté à Crumbler : ce domaine (%s) est configuré et actif. Le widget est diffusé."

#. translators: %s: domain
#: crumbler-cookie-consent.php:398
#, php-format
msgid "This domain (%s) is not authorised for the entered Site Key. Add it to the allowed domains of this site in your Crumbler dashboard. Until then the widget will not be displayed."
msgstr "Ce domaine (%s) n'est pas autorisé pour le Site Key saisi. Ajoutez-le aux domaines autorisés de ce site dans votre tableau de bord Crumbler. Jusque-là, le widget ne sera pas affiché."

#: crumbler-cookie-consent.php:401
#: crumbler-cookie-consent.php:406
#: crumbler-cookie-consent.php:411
msgid "Re-check now"
msgstr "Vérifier à nouveau"

#: crumbler-cookie-consent.php:405
msgid "The Site Key is unknown to Crumbler, or this domain is not active yet (for example the subscription or trial is not set up). The widget will not be displayed until the domain is added and active in your Crumbler dashboard."
msgstr "Le Site Key est inconnu de Crumbler, ou ce domaine n'est pas encore actif (par exemple, l'abonnement ou la période d'essai n'est pas configuré). Le widget ne sera affiché qu'une fois le domaine ajouté et actif dans votre tableau de bord Crumbler."

#: crumbler-cookie-consent.php:410
msgid "The Crumbler service status could not be verified right now (service unreachable). The widget script is still embedded on all pages."
msgstr "Le statut du service Crumbler n'a pas pu être vérifié pour le moment (service injoignable). Le script du widget reste intégré sur toutes les pages."

#: crumbler-cookie-consent.php:420
msgid "Save Settings"
msgstr "Enregistrer les réglages"

#: crumbler-cookie-consent.php:425
msgid "Integration Code"
msgstr "Code d'intégration"

#: crumbler-cookie-consent.php:427
msgid "The plugin automatically adds the following code to the <head> section:"
msgstr "L'extension ajoute automatiquement le code suivant dans la section <head> :"

#: crumbler-cookie-consent.php:431
#: crumbler-cookie-consent.php:440
#: blocks/cookie-declaration/editor.js:13
#: blocks/cookie-declaration/editor.js:53
msgid "Cookie Declaration"
msgstr "Déclaration de cookies"

#: crumbler-cookie-consent.php:433
msgid "The cookie declaration displays all detected services and cookies, grouped by category. You can embed it in two ways:"
msgstr "La déclaration de cookies affiche tous les services et cookies détectés, regroupés par catégorie. Vous pouvez l'intégrer de deux manières :"

#: crumbler-cookie-consent.php:435
msgid "Gutenberg Block"
msgstr "Bloc Gutenberg"

#. translators: %s: bold block name
#: crumbler-cookie-consent.php:439
#, php-format
msgid "Add the %s block via the block editor. The language can optionally be overridden in the block settings."
msgstr "Ajoutez le bloc %s via l'éditeur de blocs. La langue peut éventuellement être remplacée dans les réglages du bloc."

#: crumbler-cookie-consent.php:444
msgid "Shortcode"
msgstr ""

#: crumbler-cookie-consent.php:445
msgid "Use the following shortcode on any page or post:"
msgstr "Utilisez le shortcode suivant sur n'importe quelle page ou article :"

#: crumbler-cookie-consent.php:447
msgid "Optionally with a language parameter:"
msgstr "Éventuellement avec un paramètre de langue :"

#: crumbler-cookie-consent.php:576
msgid "View Cookie Declaration"
msgstr "Voir la déclaration de cookies"

#: blocks/cookie-declaration/editor.js:14
msgid "Displays the Crumbler cookie declaration."
msgstr "Affiche la déclaration de cookies Crumbler."

#: blocks/cookie-declaration/editor.js:36
msgid "Leave empty to use the plugin setting."
msgstr "Laisser vide pour utiliser le réglage de l'extension."

#: blocks/cookie-declaration/editor.js:39
msgid "Use plugin setting"
msgstr "Utiliser le réglage de l'extension"

#: blocks/cookie-declaration/editor.js:54
msgid "Displays the cookie declaration with all detected services and cookies. Data is automatically loaded from the Crumbler API on the frontend."
msgstr "Affiche la déclaration de cookies avec tous les services et cookies détectés. Les données sont automatiquement chargées depuis l'API Crumbler côté visiteur."

#: blocks/cookie-declaration/block.json
msgctxt "block title"
msgid "Cookie Declaration"
msgstr "Déclaration de cookies"

#: blocks/cookie-declaration/block.json
msgctxt "block description"
msgid "Displays the Crumbler cookie declaration with all detected services and cookies."
msgstr "Affiche la déclaration de cookies Crumbler avec tous les services et cookies détectés."

